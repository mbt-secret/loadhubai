function normalizeCountryName(value?: string | null) {
  return String(value || '')
    .normalize('NFD')
    .replace(/\p{Diacritic}/gu, '')
    .toLowerCase()
    .trim();
}

function countryCodeFromName(country?: string | null) {
  const normalized = normalizeCountryName(country);
  if (/^[a-z]{2}$/.test(normalized)) return normalized.toUpperCase();
  return COUNTRY_CODE_BY_NAME.get(normalized) || null;
}

function compactLocation(city?: string | null, country?: string | null, fallback = '') {
  const cleanCity = city?.trim();
  const cleanCountry = country?.trim();
  if (cleanCity) {
    const countryCode = countryCodeFromName(cleanCountry);
    return countryCode ? `${cleanCity}, ${countryCode}` : cleanCity;
  }
  return cleanCountry || fallback;
}

function initialSearchDraft(): SearchDraft {
  try {
    const saved = localStorage.getItem('loadhub:user-location');
    if (!saved) return defaultSearchDraft;
    const parsed = JSON.parse(saved) as Partial<SearchDraft>;
    const originSource: SearchDraft['originSource'] = parsed.originSource === 'manual' ? 'manual' : 'gps';
    return {
      ...defaultSearchDraft,
      origin: parsed.origin || defaultSearchDraft.origin,
      originSource
    };
  } catch {
    return defaultSearchDraft;
  }
}


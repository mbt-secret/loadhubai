function SearchScreen({
  query,
  setQuery,
  performSearch,
  saveSearch,
  savedSearches,
  draft,
  setDraft,
  openOrigin,
  openDestination,
  openRadius,
  openConfirm,
  onRun,
  openFilters
}: {
  query: string;
  setQuery: (value: string) => void;
  performSearch: (query?: string) => void;
  saveSearch: () => void;
  savedSearches: SavedSearch[];
  draft: SearchDraft;
  setDraft: (draft: SearchDraft) => void;
  openOrigin: () => void;
  openDestination: () => void;
  openRadius: () => void;
  openConfirm: () => void;
  onRun: () => void;
  openFilters: () => void;
}) {
  const activeFilters = [
    draft.truckType !== 'Orice',
    draft.loadDate !== 'Oricand',
    draft.messageAge !== 'Oricand',
    draft.radiusKm !== 200
  ].filter(Boolean).length;
  const [gpsBusy, setGpsBusy] = useState(false);
  const [gpsError, setGpsError] = useState<string | null>(null);
  const detectGps = () => {
    if (!navigator.geolocation) {
      setGpsError('GPS indisponibil. Scrie locația manual.');
      return;
    }
    setGpsError(null);
    setGpsBusy(true);
    navigator.geolocation.getCurrentPosition(
      (position) => {
        const detected = originFromGps(position.coords.latitude, position.coords.longitude);
        setDraft({ ...draft, origin: detected.label, originSource: 'gps' });
        setGpsBusy(false);
      },
      () => {
        setGpsError('Nu am putut detecta locația. Verifică permisiunea de localizare.');
        setGpsBusy(false);
      },
      { enableHighAccuracy: true, maximumAge: 60000, timeout: 12000 }
    );
  };
  return (
    <section className="screen-stack search-screen">
      <div className="search-head">
        <div>
          <h2 className="search-h">Caută curse</h2>
          <p className="search-sub">Setează ruta și filtrele tale</p>
        </div>
        <button className="feed-bell" onClick={saveSearch} title="Salvează căutarea">
          <Bell size={20} />
        </button>
      </div>

      <button className="sfield" onClick={openOrigin}>
        <span className="sfield-ic">
          <Navigation size={20} />
        </span>
        <span className="sfield-body">
          <small>De la</small>
          <strong>{draft.origin}</strong>
        </span>
        <span
          className={`sfield-gps ${draft.originSource === 'gps' ? 'on' : ''}`}
          role="button"
          tabIndex={0}
          onClick={(event) => {
            event.stopPropagation();
            detectGps();
          }}
        >
          <Target size={13} /> {gpsBusy ? 'Caut...' : 'GPS'}
        </span>
      </button>
      {gpsError && <p className="gps-status">{gpsError}</p>}

      <button className="sfield" onClick={openDestination}>
        <span className="sfield-ic">
          <MapPin size={20} />
        </span>
        <span className="sfield-body">
          <small>Spre</small>
          <strong>{destinationLabel(draft)}</strong>
        </span>
        <ChevronRight size={18} className="sfield-chev" />
      </button>

      <button className="filter-open-btn" onClick={openFilters}>
        <span className="fob-left">
          <SlidersHorizontal size={18} /> Filtre
        </span>
        {activeFilters > 0 ? <span className="fob-count">{activeFilters}</span> : <ChevronRight size={18} className="fob-chev" />}
      </button>

      <button className="primary-button wide" onClick={onRun}>
        <Search size={18} /> Caută curse
      </button>
    </section>
  );
}

function FilterSheet({
  open,
  onClose,
  onPrimary,
  primaryLabel,
  primaryIcon,
  title,
  draft,
  setDraft
}: {
  open: boolean;
  onClose: () => void;
  onPrimary: () => void;
  primaryLabel: string;
  primaryIcon: ReactNode;
  title: string;
  draft: SearchDraft;
  setDraft: (draft: SearchDraft) => void;
}) {
  if (!open) return null;
  const truckTypes = [
    { label: 'Orice', value: 'Orice' },
    { label: 'Prelată', value: 'Prelata' },
    { label: 'Frigo', value: 'Frigo' },
    { label: 'Mega', value: 'Mega' },
    { label: 'Basculantă', value: 'Basculanta' }
  ];
  const ageChips = [
    { label: 'Oricând', value: 'Oricand' },
    { label: '10 min', value: 'Ultimele 10 minute' },
    { label: '1 oră', value: 'Ultima ora' },
    { label: '5 ore', value: 'Ultimele 5 ore' },
    { label: '24 ore', value: 'Ultima zi' }
  ];
  const fixedDates = ['Oricand', 'Azi', 'Maine'];
  const isCustomDate = !fixedDates.includes(draft.loadDate);
  const customDateValue = (() => {
    if (!isCustomDate) return '';
    const match = draft.loadDate.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
    return match ? `${match[3]}-${match[2].padStart(2, '0')}-${match[1].padStart(2, '0')}` : '';
  })();
  const pickDate = (value: string) => {
    if (!value) {
      setDraft({ ...draft, loadDate: 'Oricand' });
      return;
    }
    const [year, month, day] = value.split('-');
    setDraft({ ...draft, loadDate: `${Number(day)}.${Number(month)}.${year}` });
  };
  const reset = () => setDraft({ ...draft, truckType: 'Orice', loadDate: 'Oricand', messageAge: 'Oricand', radiusKm: 200 });

  return (
    <div className="sheet-backdrop" onClick={onClose}>
      <div className="sheet" onClick={(event) => event.stopPropagation()}>
        <div className="sheet-handle" />
        <div className="sheet-head">
          <h3>{title}</h3>
          <button className="sheet-reset" onClick={reset}>
            Resetează
          </button>
        </div>
        <div className="sheet-body">
          <div className="sech-row">
            <b>Rază în jurul originii</b>
            <span>{draft.radiusKm} km</span>
          </div>
          <div className="feed-chips wrap">
            {[50, 100, 200, 300].map((radius) => (
              <button key={radius} className={draft.radiusKm === radius ? 'active' : ''} onClick={() => setDraft({ ...draft, radiusKm: radius })}>
                {radius} km
              </button>
            ))}
          </div>

          <div className="sech-row">
            <b>Tip camion</b>
          </div>
          <div className="feed-chips wrap">
            {truckTypes.map((truck) => (
              <button key={truck.value} className={draft.truckType === truck.value ? 'active' : ''} onClick={() => setDraft({ ...draft, truckType: truck.value })}>
                {truck.label}
              </button>
            ))}
          </div>

          <div className="sech-row">
            <b>Data plecării</b>
          </div>
          <div className="feed-chips wrap">
            <button className={draft.loadDate === 'Oricand' ? 'active' : ''} onClick={() => setDraft({ ...draft, loadDate: 'Oricand' })}>
              Oricând
            </button>
            <button className={draft.loadDate === 'Azi' ? 'active' : ''} onClick={() => setDraft({ ...draft, loadDate: 'Azi' })}>
              Azi
            </button>
            <button className={draft.loadDate === 'Maine' ? 'active' : ''} onClick={() => setDraft({ ...draft, loadDate: 'Maine' })}>
              Mâine
            </button>
            <label className={`date-chip ${isCustomDate ? 'active' : ''}`}>
              <Calendar size={14} />
              <span>{isCustomDate ? draft.loadDate : 'Calendar'}</span>

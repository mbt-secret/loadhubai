  onBack: () => void;
  onNext: () => void;
}) {
  const [filter, setFilter] = useState('');
  const [tab, setTab] = useState<SearchDraft['destinationType']>('country');
  const [options, setOptions] = useState<DestinationOption[]>([]);
  const [placesLoading, setPlacesLoading] = useState(false);

  useEffect(() => {
    let cancelled = false;
    if (tab === 'all' || tab === 'postal') {
      setOptions([]);
      setPlacesLoading(false);
      return;
    }

    setOptions([]);
    setPlacesLoading(true);
    const timeout = window.setTimeout(() => {
      api.places(tab, filter, tab === 'country' ? 80 : 60)
        .then((response) => {
          if (!cancelled) setOptions(response.items);
        })
        .catch(() => {
          if (!cancelled) setOptions([]);
        })
        .finally(() => {
          if (!cancelled) setPlacesLoading(false);
        });
    }, 160);

    return () => {
      cancelled = true;
      window.clearTimeout(timeout);
    };
  }, [filter, tab]);

  const customOption = createCustomDestinationOption(tab, filter, options);
  const renderedOptions = customOption ? [customOption, ...options] : options;
  const optionMeta = (option: DestinationOption) => {
    if (option.isCustom) return 'Destinatie introdusa manual';
    if (option.type === 'city') return [option.countryName, option.population ? `${option.population.toLocaleString('ro-RO')} loc.` : null].filter(Boolean).join(' · ');
    return option.code;
  };

  return (
    <section className="screen-stack">
      <StepHeader title="Unde vrei sa mergi?" onBack={onBack} />
      <SearchBox value={filter} onChange={setFilter} placeholder="Cauta tara, oras sau cod postal" />
      <button
        className="smart-field-button"
        onClick={() => {
          setDraft({ ...draft, destination: 'Toate', destinationType: 'all' });
          onNext();
        }}
      >
        <SmartField
          icon={<Globe2 size={19} />}
          title="Toate destinatiile"
          value="Cauta dupa incarcare, indiferent de destinatie"
          subtitle="Util pentru anunturi fara descarcare scrisa"
          action={<ChevronRight size={17} />}
        />
      </button>
      <div className="segmented">
        <button className={tab === 'country' ? 'active' : ''} onClick={() => setTab('country')}>
          Tari
        </button>
        <button className={tab === 'city' ? 'active' : ''} onClick={() => setTab('city')}>
          Orase
        </button>
        <button className={tab === 'postal' ? 'active' : ''} onClick={() => setTab('postal')}>
          Cod postal
        </button>
      </div>
      <div className="section-label">{tab === 'country' ? 'Toate tarile' : tab === 'city' ? 'Orase si cautare libera' : 'Cod postal liber'}</div>
      <div className="option-list">
        {placesLoading && (
          <div className="empty-inline">Cautam in baza locala...</div>
        )}
        {!placesLoading && renderedOptions.length === 0 && tab !== 'postal' && (
          <div className="empty-inline">Nu am gasit potriviri. Poti scrie manual orasul cautat.</div>
        )}
        {renderedOptions.map((option) => (
          <button
            key={`${option.type}-${option.code}-${option.label}`}
            onClick={() => {
              setDraft({ ...draft, destination: option.label, destinationType: option.type });
              onNext();
            }}
          >
            <span className="country-code">{option.code}</span>
            <div>
              <strong>{destinationOptionLabel(option)}</strong>
              <small>{optionMeta(option)}</small>
            </div>
            <span className={`radio-dot ${draft.destination === option.label ? 'active' : ''}`} />
          </button>
        ))}

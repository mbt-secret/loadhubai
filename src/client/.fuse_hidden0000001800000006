function routeLabel(load: Load) {
  const from = [load.loadCity, load.loadCountry].filter(Boolean).join(', ') || 'Plecare necunoscuta';
  const to = [load.unloadCity, load.unloadCountry].filter(Boolean).join(', ') || 'Destinatie necunoscuta';
  return `${from} -> ${to}`;
}

function compactRoute(load: Load) {
  const from = compactLocation(load.loadCity, load.loadCountry, 'Start');
  const to = compactLocation(load.unloadCity, load.unloadCountry, 'Destinatie');
  return `${from} -> ${to}`;
}

function hasIncludedPrice(load: Load) {
  const price = load.price?.trim().toLocaleLowerCase('ro-RO') ?? '';
  return Boolean(price && !['pret n/a', 'n/a', 'na', '0', '0 eur', '0 ron'].includes(price));
}

function originCoords(draft: SearchDraft): { lat: number; lng: number } | null {
  const known = originOptions.find((option) => option.label === draft.origin);
  if (known) return { lat: known.lat, lng: known.lng };
  const coordMatch = draft.origin.match(/(-?\d{1,2}(?:\.\d+)?)\s*,\s*(-?\d{1,3}(?:\.\d+)?)/);
  if (coordMatch) {
    const lat = Number(coordMatch[1]);
    const lng = Number(coordMatch[2]);
    if (Number.isFinite(lat) && Number.isFinite(lng)) return { lat, lng };
  }
  return null;
}

function loadContactLink(load: Load): string | null {
  const fields = [load.contact, load.originalText];
  for (const field of fields) {
    const waMatch = field?.match(/wa\.me\/(\d+)/i);
    if (waMatch) return `https://wa.me/${waMatch[1]}`;
  }
  const digits = (load.contact ?? '').replace(/\D/g, '');
  if (digits.length >= 9 && digits.length <= 15) return `https://wa.me/${digits}`;
  for (const field of fields) {
    const urlMatch = field?.match(/https?:\/\/\S+/);
    if (urlMatch) return urlMatch[0];
  }
  return null;
}

function priceValue(load: Load): number | null {
  if (!load.price) return null;
  const digits = load.price.replace(/[^\d]/g, '');
  return digits ? Number(digits) : null;
}

function formatDate(value?: string | null) {
  if (!value) return 'Nespecificat';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('ro-RO', { day: '2-digit', month: 'short' }).format(date);
}

function formatTime(value?: string | null) {
  if (!value) return '--:--';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('ro-RO', { hour: '2-digit', minute: '2-digit' }).format(date);
}

function languageLabel(value?: string | null) {
  const map: Record<string, string> = {
    ro: 'RO',
    en: 'EN',
    de: 'DE',
    it: 'IT',
    fr: 'FR',
    es: 'ES',
    hu: 'HU',
    pl: 'PL',
    unknown: 'AUTO'
  };
  return map[value ?? 'unknown'] ?? String(value).toUpperCase();
}

function readAlertDrafts(): Record<number, SearchDraft> {
  try {
    return JSON.parse(localStorage.getItem('loadhub.alertFilters') ?? '{}') as Record<number, SearchDraft>;
  } catch {
    return {};
  }
}

function writeAlertDraft(id: number, draft: SearchDraft) {
  const all = readAlertDrafts();
  all[id] = draft;
  localStorage.setItem('loadhub.alertFilters', JSON.stringify(all));
}

function App() {
  const [view, setView] = useState<View>('home');
  const [status, setStatus] = useState<WhatsappStatus>(emptyStatus);
  const [groups, setGroups] = useState<Group[]>([]);
  const [loads, setLoads] = useState<Load[]>([]);
  const [feedLoads, setFeedLoads] = useState<Load[]>([]);
  const [selectedLoad, setSelectedLoad] = useState<Load | null>(null);
  const [savedSearches, setSavedSearches] = useState<SavedSearch[]>([]);
  const [settings, setSettings] = useState<LocalSettings>(defaultSettings);
  const [query, setQuery] = useState('');
  const [searchDraft, setSearchDraft] = useState<SearchDraft>(initialSearchDraft);
  const [priceOnlyResults, setPriceOnlyResults] = useState(false);
  const [groupFilter, setGroupFilter] = useState('');
  const [loading, setLoading] = useState(false);
  const [filtersOpen, setFiltersOpen] = useState(false);
  const [alertEditor, setAlertEditor] = useState<{ id: number; draft: SearchDraft } | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notifications, setNotifications] = useState<Load[]>([]);
  const [connectingWhatsapp, setConnectingWhatsapp] = useState(false);
  const [installPrompt, setInstallPrompt] = useState<BeforeInstallPromptEvent | null>(null);
  const [installDismissed, setInstallDismissed] = useState(hasDismissedInstallPrompt);
  const [standaloneApp, setStandaloneApp] = useState(isStandaloneApp);
  const queryRef = useRef(query);
  const notificationsEnabledRef = useRef(settings.notificationsEnabled);
  useEffect(() => {
    queryRef.current = query;
  }, [query]);
  useEffect(() => {
    notificationsEnabledRef.current = settings.notificationsEnabled;
  }, [settings.notificationsEnabled]);

  async function refreshAll(activeQuery = query) {
    const [nextStatus, nextGroups, nextLoads, nextSearches, nextSettings, nextAlertMatches, nextFeed] = await Promise.all([
      api.status(),
      api.groups(),
      api.loads(activeQuery),
      api.searches(),
      api.settings(),
      api.alertMatches(),
      api.loads('')
    ]);
    const mergedSettings = { ...defaultSettings, ...nextSettings };
    setStatus(nextStatus);
    setGroups(nextGroups);
    setLoads(nextLoads);
    setFeedLoads(nextFeed);
    setSavedSearches(nextSearches);
    setSettings(mergedSettings);
    setNotifications(nextAlertMatches);
  }

  async function run(action: () => Promise<void>) {
    setLoading(true);
    setError(null);
    try {
      await action();
    } catch (currentError) {
      setError(currentError instanceof Error ? currentError.message : 'A aparut o eroare.');
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    refreshAll('').catch((currentError) => setError(currentError.message));
  }, []);

  useEffect(() => {
    const handleBeforeInstallPrompt = (event: Event) => {
      if (installDismissed || isStandaloneApp()) return;
      event.preventDefault();
      setInstallPrompt(event as BeforeInstallPromptEvent);
    };
    const handleAppInstalled = () => {
      setStandaloneApp(true);
      setInstallPrompt(null);
    };
    const displayMode = window.matchMedia('(display-mode: standalone)');
    const handleDisplayModeChange = () => setStandaloneApp(isStandaloneApp());

    window.addEventListener('beforeinstallprompt', handleBeforeInstallPrompt);
    window.addEventListener('appinstalled', handleAppInstalled);
    displayMode.addEventListener('change', handleDisplayModeChange);

    return () => {
      window.removeEventListener('beforeinstallprompt', handleBeforeInstallPrompt);
      window.removeEventListener('appinstalled', handleAppInstalled);
      displayMode.removeEventListener('change', handleDisplayModeChange);
    };
  }, [installDismissed]);

  useEffect(() => {
    localStorage.setItem(
      'loadhub:user-location',
      JSON.stringify({ origin: searchDraft.origin, originSource: searchDraft.originSource })
    );
  }, [searchDraft.origin, searchDraft.originSource]);

  useEffect(() => {
    const source = new EventSource('/api/events');
    source.onmessage = (message) => {
      let event: AppEvent;
      try {
        event = JSON.parse(message.data) as AppEvent;
      } catch {
        return;
      }
      if (event.type === 'status') setStatus(event.status);
      if (event.type === 'groups:updated') api.groups().then(setGroups).catch(() => {});
      if (event.type === 'settings:updated') {
        setSettings({ ...defaultSettings, ...event.settings });
        api.alertMatches().then(setNotifications).catch(() => {});
      }
      if (event.type === 'loads:reanalyzed') refreshAll(queryRef.current).catch(() => {});
      if (event.type === 'error') setError(event.message);
      if (event.type === 'load:new') {
        setLoads((current) => [event.load, ...current.filter((load) => load.id !== event.load.id)]);
        setFeedLoads((current) => [event.load, ...current.filter((load) => load.id !== event.load.id)]);
        if (notificationsEnabledRef.current && event.matchedSearches.length > 0) {
          setNotifications((current) => [event.load, ...current.filter((load) => load.id !== event.load.id)].slice(0, 20));
          notifyForLoad(event.load, event.matchedSearches);
        }
      }
    };
    return () => source.close();
  }, []);

  async function notifyForLoad(load: Load, matchedSearches: SavedSearch[]) {
    if (!notificationsEnabledRef.current || !('Notification' in window)) return;
    let permission = Notification.permission;
    if (permission === 'default') permission = await Notification.requestPermission();
    if (permission !== 'granted') return;
    new Notification('Cursa potrivita gasita', {
      body: `${compactRoute(load)} · ${load.price ?? 'pret n/a'} · ${matchedSearches.map((item) => item.query).join(', ')}`
    });
  }

  async function performSearch(nextQuery = query) {
    await run(async () => {
      const nextLoads = await api.loads(nextQuery);
      setLoads(nextLoads);
      setQuery(nextQuery);
      setPriceOnlyResults(false);
      setView('results');
    });
  }

  function buildDraftQuery(draft = searchDraft) {
    const origin = draft.origin.split(',')[0].trim();
    const destination = draft.destinationType === 'all' ? '' : draft.destination.trim();
    return [
      origin ? `din ${origin}` : '',
      destination ? `catre ${destination}` : '',
      draft.truckType !== 'Orice' ? draft.truckType : '',
      draft.weight !== 'Orice' ? draft.weight : '',
      draft.cargoType !== 'Orice' ? draft.cargoType : '',
      draft.loadDate !== 'Oricand' ? draft.loadDate : ''
    ]
      .filter(Boolean)
      .join(' ');
  }

  function buildDraftSearchParams(draft = searchDraft): LoadSearchParams {
    const useRadius = draft.radiusMode === 'radius';
    const coords = useRadius ? originCoords(draft) : null;
    const messageAge = messageAgeCode(draft.messageAge);
    return {
      origin: draft.origin,
      destination: draft.destinationType === 'all' ? '' : draft.destination,
      destinationType: draft.destinationType,
      truckType: draft.truckType !== 'Orice' ? draft.truckType : '',
      weight: draft.weight !== 'Orice' ? draft.weight : '',
      cargoType: draft.cargoType !== 'Orice' ? draft.cargoType : '',
      loadDate: draft.loadDate !== 'Oricand' ? draft.loadDate : '',
      price: draft.price !== 'Orice' ? draft.price : '',
      ...(messageAge ? { messageAge } : {}),
      ...(useRadius ? { radiusKm: draft.radiusKm } : {}),
      ...(coords ? { originLat: coords.lat, originLng: coords.lng } : {})
    };
  }

  async function runGuidedSearch() {
    await run(async () => {
      const smartQuery = buildDraftQuery();
      const smartFilters = buildDraftSearchParams();
      setQuery(smartQuery);
      setPriceOnlyResults(false);
      setView('searching');
      await new Promise((resolve) => setTimeout(resolve, 1100));
      setLoads(await api.loads(smartQuery, smartFilters));
      setView('results');
    });
  }

  async function saveSearch() {
    const searchQuery = query.trim() || buildDraftQuery();
    if (!searchQuery) return;
    await run(async () => {
      const created = await api.createSearch(searchQuery);
      writeAlertDraft(created.id, searchDraft);
      setQuery(searchQuery);
      const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
      setSavedSearches(nextSearches);
      setNotifications(nextAlertMatches);
      setView('saved');
      if ('Notification' in window && Notification.permission === 'default') await Notification.requestPermission();
    });
  }

  async function toggleAlert() {
    const searchQuery = query.trim() || buildDraftQuery();
    if (!searchQuery) return;
    await run(async () => {
      const existing = savedSearches.find((item) => item.query === searchQuery);
      if (existing) {
        await api.deleteSearch(existing.id);
      } else {
        const created = await api.createSearch(searchQuery);
        writeAlertDraft(created.id, searchDraft);
        if ('Notification' in window && Notification.permission === 'default') await Notification.requestPermission();
      }
      const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
      setSavedSearches(nextSearches);
      setNotifications(nextAlertMatches);
    });
  }

  function openAlertSettings(search: SavedSearch) {
    const stored = readAlertDrafts()[search.id];
    setAlertEditor({ id: search.id, draft: stored ?? { ...searchDraft } });
  }

  async function saveAlertEdits() {
    if (!alertEditor) return;
    const editor = alertEditor;
    await run(async () => {
      const nextQuery = buildDraftQuery(editor.draft);
      await api.updateSearch(editor.id, { query: nextQuery });
      writeAlertDraft(editor.id, editor.draft);
      const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
      setSavedSearches(nextSearches);
      setNotifications(nextAlertMatches);
      setAlertEditor(null);
    });
  }

  async function connectWhatsapp(nextView: View = 'connect') {
    setConnectingWhatsapp(true);
    try {
      await run(async () => {
        const nextStatus = await api.connectWhatsapp();
        setStatus(nextStatus);
        if (nextStatus.connected) {
          setGroups(await api.refreshGroups());
          setView(nextView);
        }
      });
    } finally {
      setConnectingWhatsapp(false);
    }
  }

  async function disconnectWhatsapp() {
    await run(async () => {
      setStatus(await api.disconnectWhatsapp());
    });
  }

  async function refreshWhatsappGroups() {
    await run(async () => {
      setGroups(await api.refreshGroups());
    });
  }

  async function syncGeotrans() {
    await run(async () => {
      const result = await api.syncGeotrans();
      setSettings({ ...defaultSettings, ...result.settings });
      await refreshAll(query);
    });
  }

  async function toggleGroup(group: Group) {
    await run(async () => {
      const nextGroup = await api.updateGroup(group.id, { isActive: !group.isActive });
      setGroups((current) => current.map((item) => (item.id === nextGroup.id ? nextGroup : item)));
    });
  }

  async function openLoad(load: Load) {
    await run(async () => {
      setSelectedLoad(await api.load(load.id));
      setView('detail');
    });
  }

  async function analyzeLoad(load: Load) {
    await run(async () => {
      const result = await api.analyzeLoad(load.id);
      if (result.load) {
        setSelectedLoad(result.load);
        setLoads((current) => current.map((item) => (item.id === result.load?.id ? result.load : item)));
      }
    });
  }

  function dismissInstallPrompt() {
    rememberInstallPromptDismissed();
    setInstallDismissed(true);
    setInstallPrompt(null);
  }

  async function installApp() {
    const prompt = installPrompt;
    if (!prompt) return;
    setInstallPrompt(null);

    try {
      await prompt.prompt();
      const choice = await prompt.userChoice;
      if (choice.outcome === 'dismissed') dismissInstallPrompt();
    } catch {
      setInstallPrompt(prompt);
    }
  }

  const activeGroups = useMemo(() => groups.filter((group) => group.isActive), [groups]);
  const filteredGroups = useMemo(() => {
    const normalized = groupFilter.toLowerCase();
    return groups.filter((group) => group.name.toLowerCase().includes(normalized));
  }, [groups, groupFilter]);
  const showInstallPrompt = Boolean(installPrompt && !installDismissed && !standaloneApp);

  return (
    <div className="app-stage">
      <div className="brand-panel" aria-hidden="true">
        <div className="brand-icon">
          <Truck size={38} />
          <Sparkles size={18} />
        </div>
        <h1>
          CargoCopilot <span>AI</span>
        </h1>
        <p>Asistentul tau AI pentru gasirea curselor.</p>
        <ul>
          <li>Toate sursele intr-un singur loc</li>
          <li>AI cauta si filtreaza pentru tine</li>
          <li>Traducere automata in romana</li>
          <li>Notificari instant</li>
        </ul>
      </div>

      <section className="phone-shell" aria-label="CargoCopilot AI">
        <PhoneStatus />
        {error && (
          <div className="notice error">
            <CircleAlert size={16} />
            <span>{error}</span>
          </div>
        )}
        {showInstallPrompt && <InstallPrompt onInstall={installApp} onClose={dismissInstallPrompt} />}
        <main className="app-content">
          {view === 'home' && (
            <HomeScreen
              loads={feedLoads}
              status={status}
              groups={groups}
              savedSearches={savedSearches}
              openLoad={openLoad}
              onConnect={() => setView('connect')}
              onSearch={() => setView('search')}
              onAlerts={() => setView('notifications')}
            />
          )}
          {view === 'connect' && (
            <ConnectScreen
              status={status}
              loading={loading}
              onConnect={() => connectWhatsapp('connect')}
              onDisconnect={disconnectWhatsapp}
            />
          )}
          {view === 'groups' && (
            <GroupsScreen
              groups={filteredGroups}
              activeGroups={activeGroups}
              groupFilter={groupFilter}
              setGroupFilter={setGroupFilter}
              toggleGroup={toggleGroup}
              loading={loading}
              onRefreshGroups={refreshWhatsappGroups}
            />
          )}
          {view === 'search' && (
            <SearchScreen
              query={query}
              setQuery={setQuery}
              performSearch={performSearch}
              saveSearch={saveSearch}
              savedSearches={savedSearches}
              draft={searchDraft}
              setDraft={setSearchDraft}
              openOrigin={() => setView('origin')}
              openDestination={() => setView('destination')}
              openRadius={() => setView('radius')}
              openConfirm={() => setView('confirm')}
              onRun={runGuidedSearch}
              openFilters={() => setFiltersOpen(true)}
            />
          )}
          {view === 'origin' && (
            <OriginScreen
              draft={searchDraft}
              setDraft={setSearchDraft}
              onBack={() => setView('search')}
            />
          )}
          {view === 'destination' && (
            <DestinationScreen
              draft={searchDraft}
              setDraft={setSearchDraft}
              onBack={() => setView('search')}
              onNext={() => setView('search')}
            />
          )}
          {view === 'radius' && (
            <RadiusScreen
              draft={searchDraft}
              setDraft={setSearchDraft}
              onBack={() => setView('destination')}
              onApply={() => setView('confirm')}
            />
          )}
          {view === 'confirm' && (
            <ConfirmSearchScreen
              draft={searchDraft}
              setDraft={setSearchDraft}
              onBack={() => setView('radius')}
              onSearch={runGuidedSearch}
              expectedCount={loads.length || 42}
            />
          )}
          {view === 'searching' && <SearchingScreen onCancel={() => setView('search')} />}
          {view === 'summary' && (
            <SearchSummaryScreen
              draft={searchDraft}
              loads={loads}
              onBack={() => setView('confirm')}
              onEdit={() => setView('search')}
              onResults={() => setView('results')}
              onSave={saveSearch}
            />
          )}
          {view === 'results' && (
            <ResultsScreen
              query={query}
              loads={loads}
              priceOnly={priceOnlyResults}
              setPriceOnly={setPriceOnlyResults}
              performSearch={performSearch}
              openLoad={openLoad}
              setQuery={setQuery}
              goMap={() => setView('map')}
              savedSearches={savedSearches}
              onToggleAlert={toggleAlert}
            />
          )}
          {view === 'map' && <MapScreen openLoad={openLoad} goList={() => setView('results')} />}
          {view === 'detail' && selectedLoad && (
            <DetailScreen
              load={selectedLoad}
              loading={loading}
              onBack={() => setView('results')}
              onAnalyze={() => analyzeLoad(selectedLoad)}
              onSave={async (patch) => {
                await run(async () => {
                  const nextLoad = await api.updateLoad(selectedLoad.id, patch);
                  setSelectedLoad(nextLoad);
                  setLoads((current) => current.map((load) => (load.id === nextLoad.id ? nextLoad : load)));
                });
              }}
            />
          )}
          {view === 'detail' && !selectedLoad && <EmptyState title="Nu ai selectat inca o cursa." />}
          {view === 'notifications' && (
            <NotificationsScreen
              notifications={notifications}
              savedSearches={savedSearches}
              openLoad={openLoad}
              performSearch={performSearch}
              onEditAlert={openAlertSettings}
              onToggleSearch={async (search) => {
                await run(async () => {
                  await api.updateSearch(search.id, { notificationsEnabled: !search.notificationsEnabled });
                  const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
                  setSavedSearches(nextSearches);
                  setNotifications(nextAlertMatches);
                });
              }}
              onDeleteSearch={async (search) => {
                await run(async () => {
                  await api.deleteSearch(search.id);
                  const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
                  setSavedSearches(nextSearches);
                  setNotifications(nextAlertMatches);
                });
              }}
            />
          )}
          {view === 'saved' && (
            <SavedSearchesScreen
              savedSearches={savedSearches}
              performSearch={performSearch}
              onToggleSearch={async (search) => {
                await run(async () => {
                  await api.updateSearch(search.id, { notificationsEnabled: !search.notificationsEnabled });
                  const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
                  setSavedSearches(nextSearches);
                  setNotifications(nextAlertMatches);
                });
              }}
              onDeleteSearch={async (search) => {
                await run(async () => {
                  await api.deleteSearch(search.id);
                  const [nextSearches, nextAlertMatches] = await Promise.all([api.searches(), api.alertMatches()]);
                  setSavedSearches(nextSearches);
                  setNotifications(nextAlertMatches);
                });
              }}
            />
          )}
          {view === 'settings' && (
            <SettingsScreen
              status={status}
              settings={settings}
              groups={groups}
              savedSearches={savedSearches}
              onConnect={() => connectWhatsapp('settings')}
              onDisconnect={disconnectWhatsapp}
              loading={loading}
              connectingWhatsapp={connectingWhatsapp}
              onToggleSettings={async (patch) => {
                await run(async () => {
                  const nextSettings = await api.updateSettings(patch);
                  setSettings(nextSettings);
                  setNotifications(await api.alertMatches());
                });
              }}
              onSyncGeotrans={syncGeotrans}
              onToggleGroup={toggleGroup}
              onClearData={async () => {
                if (!window.confirm('Stergi mesajele, cursele, grupurile si sesiunea WhatsApp locala?')) return;
                await run(async () => {
                  await api.clearLocalData();
                  setSelectedLoad(null);
                  setQuery('');
                  await refreshAll('');
                  setView('connect');
                });
              }}
            />
          )}
        </main>
        <BottomNav view={view} setView={setView} selectedLoad={selectedLoad} notificationCount={notifications.length} />
        <FilterSheet
          open={filtersOpen}
          onClose={() => setFiltersOpen(false)}
          onPrimary={() => {
            setFiltersOpen(false);
            runGuidedSearch();
          }}
          primaryLabel="Caută"
          primaryIcon={<Search size={18} />}
          title="Filtre"
          draft={searchDraft}
          setDraft={setSearchDraft}
        />
        <FilterSheet
          open={Boolean(alertEditor)}
          onClose={() => setAlertEditor(null)}
          onPrimary={saveAlertEdits}
          primaryLabel="Salvează"
          primaryIcon={<Check size={18} />}
          title="Setări alertă"
          draft={alertEditor?.draft ?? defaultSearchDraft}
          setDraft={(next) => setAlertEditor((current) => (current ? { ...current, draft: next } : current))}
        />
      </section>
    </div>
  );
}


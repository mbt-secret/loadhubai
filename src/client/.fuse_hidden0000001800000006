function SettingsScreen({
  status,
  settings,
  groups,
  savedSearches,
  onConnect,
  onDisconnect,
  loading,
  connectingWhatsapp,
  onToggleSettings,
  onSyncGeotrans,
  onToggleGroup,
  onClearData
}: {
  status: WhatsappStatus;
  settings: LocalSettings;
  groups: Group[];
  savedSearches: SavedSearch[];
  onConnect: () => void;
  onDisconnect: () => void;
  loading: boolean;
  connectingWhatsapp: boolean;
  onToggleSettings: (patch: Partial<LocalSettings>) => void;
  onSyncGeotrans: () => void;
  onToggleGroup: (group: Group) => void;
  onClearData: () => void;
}) {
  const activeGroupCount = groups.filter((group) => group.isActive).length;
  const defaultConnectionOrder: Array<'whatsapp' | 'viber'> = ['whatsapp', 'viber'];
  const [connectionOrder, setConnectionOrder] = useState<Array<'whatsapp' | 'viber'>>(() => {
    try {
      const saved = JSON.parse(localStorage.getItem('loadhub.connectionOrder') ?? '[]') as Array<'whatsapp' | 'viber'>;
      const valid = saved.filter((item) => defaultConnectionOrder.includes(item));
      return [...valid, ...defaultConnectionOrder.filter((item) => !valid.includes(item))];
    } catch {
      return defaultConnectionOrder;
    }
  });
  const [draggedConnection, setDraggedConnection] = useState<'whatsapp' | 'viber' | null>(null);
  const [connectionPanel, setConnectionPanel] = useState<'whatsapp' | 'viber' | null>(null);
  const [draggedGroupId, setDraggedGroupId] = useState<number | null>(null);
  const [groupOrder, setGroupOrder] = useState<number[]>(() => {
    try {
      const saved = JSON.parse(localStorage.getItem('loadhub.whatsappGroupOrder') ?? '[]') as number[];
      return Array.isArray(saved) ? saved.filter(Number.isFinite) : [];
    } catch {
      return [];
    }
  });
  useEffect(() => {
    localStorage.setItem('loadhub.connectionOrder', JSON.stringify(connectionOrder));
  }, [connectionOrder]);
  useEffect(() => {
    setGroupOrder((current) => {
      const groupIds = groups.map((group) => group.id);
      const valid = current.filter((id) => groupIds.includes(id));
      const missing = groupIds.filter((id) => !valid.includes(id));
      return [...valid, ...missing];
    });
  }, [groups]);
  useEffect(() => {
    localStorage.setItem('loadhub.whatsappGroupOrder', JSON.stringify(groupOrder));
  }, [groupOrder]);
  const moveConnection = (target: 'whatsapp' | 'viber') => {
    if (!draggedConnection || draggedConnection === target) return;
    setConnectionOrder((current) => {
      const next = current.filter((item) => item !== draggedConnection);
      const targetIndex = next.indexOf(target);
      next.splice(targetIndex, 0, draggedConnection);
      return next;
    });
  };
  const orderedGroups = groupOrder
    .map((id) => groups.find((group) => group.id === id))
    .filter((group): group is Group => Boolean(group));
  const moveGroup = (targetId: number) => {
    if (!draggedGroupId || draggedGroupId === targetId) return;
    setGroupOrder((current) => {
      const next = current.filter((id) => id !== draggedGroupId);
      const targetIndex = next.indexOf(targetId);
      next.splice(targetIndex, 0, draggedGroupId);
      return next;
    });
  };
  const whatsappActionLabel = connectingWhatsapp ? 'Se conecteaza...' : status.connected ? 'Deconecteaza' : 'Conecteaza';
  const connectionItems = {
    whatsapp: {
      icon: <MessageCircle size={17} />,
      title: 'WhatsApp',
      subtitle: status.connected ? 'Conectat' : 'Neconectat',
      state: status.connected ? 'online' : 'offline',
      action: (
        <>
          <button className={status.connected ? 'compact-danger-button' : 'compact-primary-button'} onClick={status.connected ? onDisconnect : onConnect} disabled={loading || connectingWhatsapp}>
            {whatsappActionLabel}
          </button>
          <button
            className={`icon-button small ${connectionPanel === 'whatsapp' ? 'active' : ''}`}
            onClick={() => setConnectionPanel((current) => current === 'whatsapp' ? null : 'whatsapp')}
            title="Setări WhatsApp"
          >
            <Settings size={15} />
          </button>
        </>
      )
    },
    viber: {
      icon: <PhoneCall size={17} />,
      title: 'Viber',
      subtitle: 'Pregatit pentru integrare',
      state: 'soon',
      action: (
        <>
          <button className="compact-muted-button" disabled>In curand</button>
          <button
            className={`icon-button small ${connectionPanel === 'viber' ? 'active' : ''}`}
            onClick={() => setConnectionPanel((current) => current === 'viber' ? null : 'viber')}
            title="Setări Viber"
          >
            <Settings size={15} />
          </button>
        </>
      )
    }
  } satisfies Record<'whatsapp' | 'viber', {
    icon: ReactNode;
    title: string;
    subtitle: string;
    state: 'online' | 'offline' | 'soon';
    action: ReactNode;
  }>;
  const handleDragStart = (event: DragEvent<HTMLDivElement>, id: 'whatsapp' | 'viber') => {
    setDraggedConnection(id);
    event.dataTransfer.effectAllowed = 'move';
  };
  const handlePointerStart = (event: PointerEvent<HTMLDivElement>, id: 'whatsapp' | 'viber') => {
    const target = event.target as HTMLElement;
    if (target.closest('button, label, input')) return;
    setDraggedConnection(id);
  };
  const handleGroupDragStart = (event: DragEvent<HTMLDivElement>, groupId: number) => {
    setDraggedGroupId(groupId);
    event.dataTransfer.effectAllowed = 'move';
  };
  const handleGroupPointerStart = (event: PointerEvent<HTMLDivElement>, groupId: number) => {
    const target = event.target as HTMLElement;
    if (target.closest('button, label, input')) return;
    setDraggedGroupId(groupId);
  };

  return (
    <section className="screen-stack settings-compact">
      <ScreenHeader title="Setări" subtitle="Conexiuni, surse si date locale." />

      <div className="expedition-card">
        <div className="inner">
          <span className="soon-badge">IN CURAND</span>
          <div className="expedition-body">
            <Package size={28} />
            <div>
              <strong>Case de expeditii</strong>
              <small>Primeste curse direct de la casele de expeditii partenere, nu doar din grupurile WhatsApp.</small>
            </div>
          </div>
        </div>
      </div>

      <div className="settings-section">
        <div className="settings-section-head">
          <span>Conexiuni</span>
          <small>{status.connected ? '1 activa' : '0 active'}</small>
        </div>
        <div className="compact-list">
          {connectionOrder.map((id) => {
            const item = connectionItems[id];
            return (
              <div
                className={`compact-row connection-row ${draggedConnection === id ? 'dragging' : ''}`}
                draggable
                key={id}
                onDragStart={(event) => handleDragStart(event, id)}
                onDragOver={(event) => event.preventDefault()}
                onDrop={() => moveConnection(id)}
                onDragEnd={() => setDraggedConnection(null)}
                onPointerDown={(event) => handlePointerStart(event, id)}
                onPointerEnter={() => moveConnection(id)}
                onPointerUp={() => setDraggedConnection(null)}
                onPointerCancel={() => setDraggedConnection(null)}
              >
                <span className="drag-handle" aria-hidden="true">
                  <GripVertical size={16} />
                </span>
                <RowIcon icon={item.icon} title={item.title} subtitle={item.subtitle} />
                <span className={`status-dot ${item.state}`} />
                <div className="compact-actions">{item.action}</div>
              </div>
            );
          })}
        </div>
        <p className="help-text compact">{status.message}</p>
        {status.qrCodeDataUrl && !status.connected && (
          <div className="whatsapp-qr-card">
            <img className="qr-image compact" src={status.qrCodeDataUrl} alt="Cod QR WhatsApp" />
            <small>Scaneaza codul din WhatsApp: Dispozitive asociate &gt; Asociaza un dispozitiv.</small>
          </div>
        )}
        {connectionPanel === 'whatsapp' && (
          <div className="connection-panel">
            <div className="settings-section-head">
              <span>Grupuri WhatsApp</span>
              <small>{activeGroupCount}/{groups.length}</small>
            </div>
            {orderedGroups.length > 0 ? (
              <div className="settings-list compact groups-compact">
                {orderedGroups.map((group) => (
                  <div
                    className={`group-drag-row ${draggedGroupId === group.id ? 'dragging' : ''}`}
                    draggable
                    key={group.id}
                    onDragStart={(event) => handleGroupDragStart(event, group.id)}
                    onDragOver={(event) => event.preventDefault()}
                    onDrop={() => moveGroup(group.id)}
                    onDragEnd={() => setDraggedGroupId(null)}
                    onPointerDown={(event) => handleGroupPointerStart(event, group.id)}
                    onPointerEnter={() => moveGroup(group.id)}
                    onPointerUp={() => setDraggedGroupId(null)}
                    onPointerCancel={() => setDraggedGroupId(null)}
                  >
                    <span className="drag-handle" aria-hidden="true">
                      <GripVertical size={15} />
                    </span>
                    <div className="group-drag-title">
                      <strong>{group.name}</strong>
                      <small>{group.isActive ? 'Monitorizat' : 'Oprit'}</small>
                    </div>
                    <label className="switch">
                      <input type="checkbox" checked={group.isActive} onChange={() => onToggleGroup(group)} />
                      <span />
                    </label>
                  </div>
                ))}
              </div>
            ) : (
              <div className="settings-empty compact">
                <Users size={17} />
                <span>Nu sunt grupuri detectate inca.</span>
              </div>
            )}
          </div>
        )}
        {connectionPanel === 'viber' && (
          <div className="connection-panel">
            <div className="settings-section-head">
              <span>Grupuri Viber</span>
              <small>In curand</small>
            </div>
            <div className="settings-empty compact">
              <PhoneCall size={17} />
              <span>Conectorul Viber va folosi aceeasi zona pentru grupuri cand va fi activ.</span>
            </div>
          </div>
        )}
      </div>

      <div className="settings-section">
        <div className="settings-section-head">
          <span>Surse</span>
          <small>{settings.geotransEnabled ? 'GeoTrans activ' : 'GeoTrans oprit'}</small>
        </div>
        <div className="compact-list">
          <div className="compact-row">
            <RowIcon
              icon={<Globe2 size={17} />}
              title="GeoTrans.md"
              subtitle={settings.geotransLastSyncAt ? `Ultim import ${formatTime(settings.geotransLastSyncAt)}` : 'Sursa publica'}
            />
            <label className="switch">
              <input
                type="checkbox"
                checked={settings.geotransEnabled}
                onChange={() => onToggleSettings({ geotransEnabled: !settings.geotransEnabled })}
              />
              <span />
            </label>
            <button className="icon-button small" onClick={onSyncGeotrans} disabled={!settings.geotransEnabled || loading} title="Importa GeoTrans.md">
              <RefreshCw size={15} />
            </button>
          </div>
        </div>
        {settings.geotransLastSyncError && <p className="help-text compact error-text">{settings.geotransLastSyncError}</p>}
        {settings.geotransLastSyncAt && <small className="sync-note compact">{settings.geotransLastSyncCount} curse noi la ultimul import</small>}
      </div>

      <div className="settings-section">
        <div className="settings-section-head">
          <span>Preferinte</span>
          <small>Local</small>
        </div>
        <div className="compact-list">
          <div className="compact-row">
            <RowIcon icon={<Bell size={17} />} title="Notificări" subtitle={settings.notificationsEnabled ? 'Active' : 'Oprite'} />
            <label className="switch">
              <input type="checkbox" checked={settings.notificationsEnabled} onChange={() => onToggleSettings({ notificationsEnabled: !settings.notificationsEnabled })} />
              <span />
            </label>
          </div>
          <div className="compact-row">
            <RowIcon icon={<Languages size={17} />} title="Limba aplicatiei" subtitle="Romana" />
            <ChevronRight size={17} />
          </div>
          <div className="compact-row">
            <RowIcon icon={<BellOff size={17} />} title="Cautari salvate" subtitle={`${savedSearches.length} salvate`} />
            <ChevronRight size={17} />
          </div>
        </div>
      </div>

      <button className="danger-button compact-danger-row" onClick={onClearData}>
        <Database size={17} />
        Sterge datele locale
      </button>
    </section>
  );
}

function ScreenHeader({ title, subtitle, badge }: { title: string; subtitle?: string; badge?: string }) {
  return (
    <div className="screen-header">
      <div>
        <h2>
          {title} {badge && <span className="ai-badge">{badge}</span>}
        </h2>
        {subtitle && <p>{subtitle}</p>}
      </div>
    </div>
  );
}

function SearchBox({ value, onChange, placeholder }: { value: string; onChange: (value: string) => void; placeholder: string }) {
  return (
    <label className="search-box">
      <Search size={17} />
      <input value={value} onChange={(event) => onChange(event.target.value)} placeholder={placeholder} />
    </label>
  );
}

function DetailRow({ label, value, note }: { label: string; value: string; note?: string }) {
  return (
    <div>
      <span>{label}</span>
      <strong>{value || 'Nespecificat'}</strong>
      {note && <small className="verify-note">{note}</small>}
    </div>
  );
}

function RowIcon({ icon, title, subtitle }: { icon: ReactNode; title: string; subtitle: string }) {
  return (
    <div className="row-icon">
      <span className="mini-icon">{icon}</span>
      <div>
        <strong>{title}</strong>
        <small>{subtitle}</small>
      </div>
    </div>
  );
}

function ToggleRow({ title, checked, onChange }: { title: string; checked: boolean; onChange: () => void }) {
  return (
    <div className="toggle-row">
      <strong>{title}</strong>
      <label className="switch">
        <input type="checkbox" checked={checked} onChange={onChange} />
        <span />
      </label>
    </div>
  );
}

function TextInput({
  label,
  value,
  type = 'text',
  placeholder,
  onChange
}: {
  label: string;
  value: string;
  type?: string;
  placeholder?: string;
  onChange: (value: string) => void;
}) {
  return (
    <label className="field">
      <span>{label}</span>
      <input type={type} value={value} placeholder={placeholder} onChange={(event) => onChange(event.target.value)} />
    </label>
  );
}

function EmptyState({ title }: { title: string }) {
  return (
    <div className="empty-state">
      <Truck size={28} />
      <strong>{title}</strong>
    </div>
  );
}

function BottomNav({
  view,
  setView,
  selectedLoad,
  notificationCount
}: {
  view: View;
  setView: (view: View) => void;
  selectedLoad: Load | null;
  notificationCount: number;
}) {
  const searchViews: View[] = ['search', 'destination', 'radius', 'confirm', 'searching', 'summary', 'results'];
  return (
    <nav className="bottom-nav" aria-label="Navigare">
      <NavItem icon={<LayoutGrid size={22} />} label="Feed" active={view === 'home'} onClick={() => setView('home')} />
      <NavItem icon={<Search size={22} />} label="Caută" active={searchViews.includes(view)} onClick={() => setView('search')} />
      <NavItem icon={<MapPinned size={22} />} label="Hartă" active={view === 'map'} onClick={() => setView('map')} />
      <NavItem
        icon={<Bell size={22} />}
        label="Alerte"
        active={view === 'notifications'}
        badge={notificationCount}
        onClick={() => setView('notifications')}
      />
      <NavItem icon={<User size={22} />} label="Cont" active={view === 'settings'} onClick={() => setView('settings')} />
    </nav>
  );
}

function NavItem({
  icon,
  label,
  active,
  badge,
  onClick
}: {
  icon: ReactNode;
  label: string;
  active: boolean;
  badge?: number;
  onClick: () => void;
}) {
  return (
    <button className={`nav-item ${active ? 'active' : ''}`} onClick={onClick}>
      <span>
        {icon}
        {Boolean(badge) && <i>{badge}</i>}
      </span>
      <small>{label}</small>
    </button>
  );
}

export default App;
